<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usar VPN</title>
    <!-- Leaflet Map -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --success: #22c55e;
            --error: #ef4444;
            --warning: #f59e0b;
            --bg: #0f172a;
            --card-bg: #1e293b;
            --text: #f8fafc;
            --text-muted: #94a3b8;
        }

        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh;
            color: var(--text);
        }

        /* HOME PAGE */
        .home-container {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .card {
            background: var(--card-bg);
            border-radius: 24px;
            padding: 40px;
            max-width: 500px;
            width: 100%;
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            animation: slideUp 0.5s ease;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .icon {
            font-size: 64px;
            margin-bottom: 20px;
        }

        .icon.success { color: var(--success); }
        .icon.error { color: var(--error); }

        h1 {
            font-size: 28px;
            margin-bottom: 16px;
            font-weight: 700;
        }

        p {
            color: var(--text-muted);
            margin-bottom: 12px;
            line-height: 1.6;
        }

        .privacy-note {
            font-size: 14px;
            background: rgba(99, 102, 241, 0.1);
            padding: 12px;
            border-radius: 12px;
            border-left: 4px solid var(--primary);
            margin: 20px 0;
            text-align: left;
        }

        .buttons {
            display: flex;
            gap: 12px;
            margin-top: 24px;
            flex-wrap: wrap;
        }

        .btn {
            flex: 1;
            padding: 16px 24px;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-width: 140px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
        }

        .btn-primary:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px -10px var(--primary);
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.1);
            color: var(--text);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .hidden {
            display: none !important;
        }

        .location-info {
            background: rgba(0, 0, 0, 0.3);
            padding: 20px;
            border-radius: 16px;
            margin: 20px 0;
            text-align: left;
        }

        .location-info p {
            margin-bottom: 8px;
            font-family: monospace;
            font-size: 14px;
        }

        .location-info strong {
            color: var(--primary);
        }

        .session-id {
            font-size: 12px;
            color: var(--text-muted);
            font-family: monospace;
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .error-text {
            color: var(--error);
            font-weight: 500;
        }

        .pulse {
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: var(--primary);
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ADMIN PAGE */
        .admin-body {
            background: #0a0a0a;
        }

        .admin-header {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            flex-wrap: wrap;
            gap: 20px;
        }

        .admin-header h1 {
            margin: 0;
            font-size: 24px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-small {
            padding: 10px 20px;
            font-size: 14px;
        }

        .stats {
            display: flex;
            gap: 30px;
        }

        .stat {
            text-align: center;
        }

        .stat-number {
            display: block;
            font-size: 32px;
            font-weight: 700;
            color: var(--primary);
            transition: all 0.3s;
        }

        .stat-number.updated {
            color: var(--success);
            transform: scale(1.2);
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .admin-container {
            display: flex;
            height: calc(100vh - 80px);
        }

        .sidebar {
            width: 400px;
            background: #1a1a1a;
            padding: 20px;
            overflow-y: auto;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
        }

        .sidebar h2 {
            font-size: 18px;
            margin-bottom: 20px;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 8px;
            justify-content: space-between;
        }

        .users-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .user-card {
            background: #252525;
            padding: 16px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
        }

        .user-card:hover {
            border-color: var(--primary);
            transform: translateX(4px);
        }

        .user-card.inactive {
            opacity: 0.6;
            border-left: 3px solid var(--error);
        }

        .user-card.active {
            border-left: 3px solid var(--success);
        }

        .user-header {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 12px;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--error);
            position: relative;
        }

        .status-dot.online {
            background: var(--success);
            box-shadow: 0 0 10px var(--success);
        }

        .status-dot.online::after {
            content: '';
            position: absolute;
            top: -4px;
            left: -4px;
            right: -4px;
            bottom: -4px;
            border-radius: 50%;
            border: 2px solid var(--success);
            animation: ripple 2s infinite;
        }

        @keyframes ripple {
            0% { transform: scale(1); opacity: 1; }
            100% { transform: scale(2); opacity: 0; }
        }

        .user-details {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 12px;
        }

        .user-details p {
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-map {
            width: 100%;
            padding: 8px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.3s;
        }

        .btn-map:hover {
            background: var(--primary-dark);
        }

        .map-container {
            flex: 1;
            position: relative;
        }

        #map {
            width: 100%;
            height: 100%;
        }

        .empty-state {
            text-align: center;
            color: var(--text-muted);
            padding: 40px;
        }

        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-online {
            background: rgba(34, 197, 94, 0.2);
            color: var(--success);
        }

        .badge-offline {
            background: rgba(239, 68, 68, 0.2);
            color: var(--error);
        }

        .sync-indicator {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            z-index: 1000;
            background: rgba(34, 197, 94, 0.9);
            color: white;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .sync-indicator.syncing {
            background: rgba(245, 158, 11, 0.9);
        }

        .file-input {
            display: none;
        }

        /* Responsivo */
        @media (max-width: 768px) {
            .admin-container {
                flex-direction: column;
            }
            
            .sidebar {
                width: 100%;
                height: 50vh;
                order: 2;
            }
            
            .map-container {
                height: 50vh;
                order: 1;
            }
            
            .admin-header {
                padding: 15px;
            }
            
            .header-actions {
                width: 100%;
                justify-content: center;
            }
            
            .buttons {
                flex-direction: column;
            }
        }

        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #1a1a1a;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 4px;
        }

        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: var(--success);
            color: white;
            padding: 16px 24px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            transform: translateX(400px);
            transition: transform 0.3s ease;
            z-index: 2000;
        }

        .toast.show {
            transform: translateX(0);
        }

        .toast.error {
            background: var(--error);
        }
    </style>
<base target="_blank">
</head>
<body>
    <!-- PÁGINA INICIAL -->
    <div id="homePage" class="home-container">
        <div class="card" id="requestCard">
            <div class="icon">📍</div>
            <h1>Permitir Localização?</h1>
            <p>Este site demonstra geolocalização em tempo real entre abas.</p>
            
            <div class="privacy-note">
                <strong>🔒 Como funciona:</strong><br>
                • A localização fica apenas no teu browser (LocalStorage)<br>
                • Abre o Painel Admin noutra aba para ver em tempo real<br>
                • Usa BroadcastChannel para comunicação instantânea<br>
                • Podes exportar/importar dados como JSON
            </div>
            
            <div class="buttons">
                <button id="allowBtn" class="btn btn-primary">
                    Permitir VPN
                </button>
                <button id="denyBtn" class="btn btn-secondary">
                    Recusar
                </button>
            </div>
            
            <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1);">
                <a href="?admin" class="btn btn-secondary btn-small">
                    🔐 Ser hackeado
                </a>
            </div>
        </div>

        <div class="card hidden" id="successCard">
            <div class="icon success">✅</div>
            <h1>A Partilhar Localização!</h1>
            <p>Os dados estão sincronizados em tempo real.</p>
            
            <div class="location-info">
                <p><strong>📍 Latitude:</strong> <span id="lat">--</span></p>
                <p><strong>📍 Longitude:</strong> <span id="lng">--</span></p>
                <p><strong>🎯 Precisão:</strong> <span id="accuracy">--</span> metros</p>
                <p><strong>🕐 Atualizado:</strong> <span id="timestamp">--</span></p>
                <p><strong>📡 Status:</strong> <span id="status" class="pulse">A sincronizar...</span></p>
            </div>
            
            <div class="session-id">
                ID: <span id="sessionId">--</span><br>
                <small>Deixa assim espera ser hackeado.</small>
            </div>

            <div class="buttons" style="margin-top: 20px;">
                <button onclick="exportData()" class="btn btn-secondary btn-small">
                    💾 Exportar JSON
                </button>
                <button onclick="location.reload()" class="btn btn-secondary btn-small">
                    🔄 Nova Sessão
                </button>
            </div>
        </div>

        <div class="card hidden" id="errorCard">
            <div class="icon error">❌</div>
            <h1>Acesso Negado</h1>
            <p id="errorMessage" class="error-text"></p>
            <button onclick="location.reload()" class="btn btn-primary" style="margin-top: 20px;">
                Tentar Novamente
            </button>
        </div>
    </div>

    <!-- PAINEL ADMIN -->
    <div id="adminPage" class="hidden admin-body">
        <div class="sync-indicator" id="syncStatus">
            <span class="status-dot online" style="position: static;"></span>
            <span>Em tempo real</span>
        </div>

        <div class="admin-header">
            <h1>🗺️ Painel de Localizações</h1>
            
            <div class="header-actions">
                <button onclick="exportData()" class="btn btn-secondary btn-small">
                    💾 Exportar JSON
                </button>
                <label class="btn btn-secondary btn-small" style="cursor: pointer;">
                    📁 Importar JSON
                    <input type="file" class="file-input" accept=".json" onchange="importData(this)">
                </label>
                <button onclick="clearAll()" class="btn btn-secondary btn-small" style="background: rgba(239, 68, 68, 0.2); color: var(--error);">
                    🗑️ Limpar Tudo
                </button>
                <a href="?" class="btn btn-primary btn-small">
                    ➕ Nova Localização
                </a>
            </div>

            <div class="stats">
                <div class="stat">
                    <span class="stat-number" id="totalUsers">0</span>
                    <span class="stat-label">Total</span>
                </div>
                <div class="stat">
                    <span class="stat-number" id="onlineUsers">0</span>
                    <span class="stat-label">Online</span>
                </div>
                <div class="stat">
                    <span class="stat-number" id="lastUpdate">--:--:--</span>
                    <span class="stat-label">Atualização</span>
                </div>
            </div>
        </div>

        <div class="admin-container">
            <div class="sidebar">
                <h2>
                    📋 Utilizadores
                    <span id="userCount" class="badge badge-online">0</span>
                </h2>
                <div id="usersList" class="users-list">
                    <div class="empty-state">
                        <div class="loading-spinner"></div>
                        <p>Aguardando dados...</p>
                        <small>Abre a página inicial noutra aba e permite localização</small>
                    </div>
                </div>
            </div>
            
            <div class="map-container">
                <div id="map"></div>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <script>
        // ==========================================
        // SISTEMA DE ARMAZENAMENTO & SINCRONIZAÇÃO
        // ==========================================
        
        const STORAGE_KEY = 'location_tracker_data';
        const BROADCAST_KEY = 'location_tracker_channel';
        
        let sessionId = null;
        let updateInterval = null;
        let broadcastChannel = null;
        let map = null;
        let markers = {};
        let isAdmin = false;

        // Inicializar BroadcastChannel (comunicação entre abas)
        function initBroadcast() {
            if ('BroadcastChannel' in window) {
                broadcastChannel = new BroadcastChannel(BROADCAST_KEY);
                broadcastChannel.onmessage = (event) => {
                    const { type, data } = event.data;
                    if (type === 'location_update') {
                        refreshData();
                    } else if (type === 'request_sync') {
                        if (!isAdmin) sendLocationToAdmin();
                    }
                };
            }
        }

        // Guardar dados no LocalStorage
        function saveToStorage(data) {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
            // Notificar outras abas
            if (broadcastChannel) {
                broadcastChannel.postMessage({ type: 'location_update', data: Date.now() });
            }
            // Evento para abas antigas (fallback)
            window.dispatchEvent(new StorageEvent('storage', { key: STORAGE_KEY }));
        }

        // Ler dados do LocalStorage
        function getFromStorage() {
            const data = localStorage.getItem(STORAGE_KEY);
            return data ? JSON.parse(data) : {};
        }

        // ==========================================
        // INICIALIZAÇÃO
        // ==========================================
        
        document.addEventListener('DOMContentLoaded', () => {
            initBroadcast();
            
            const urlParams = new URLSearchParams(window.location.search);
            isAdmin = urlParams.has('admin');

            if (isAdmin) {
                initAdmin();
            } else {
                initHome();
            }

            // Escutar mudanças no storage (outras abas)
            window.addEventListener('storage', (e) => {
                if (e.key === STORAGE_KEY) {
                    if (isAdmin) refreshData();
                }
            });
        });

        // ==========================================
        // PÁGINA INICIAL (USER)
        // ==========================================
        
        function initHome() {
            document.getElementById('homePage').classList.remove('hidden');
            document.getElementById('adminPage').classList.add('hidden');

            document.getElementById('allowBtn').addEventListener('click', requestLocation);
            document.getElementById('denyBtn').addEventListener('click', () => {
                showError('Recusaste partilhar a localização.');
            });

            // Pedir sync se já existe admin aberto
            if (broadcastChannel) {
                broadcastChannel.postMessage({ type: 'request_sync' });
            }
        }

        function requestLocation() {
            if (!navigator.geolocation) {
                showError('Geolocalização não suportada.');
                return;
            }

            const btn = document.getElementById('allowBtn');
            btn.innerHTML = '<span class="loading-spinner" style="width: 16px; height: 16px; border-width: 2px;"></span>';
            btn.disabled = true;

            navigator.geolocation.getCurrentPosition(
                handleSuccess,
                handleError,
                { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
            );
        }

        function handleSuccess(position) {
            const { latitude, longitude, accuracy } = position.coords;
            sessionId = 'user_' + Math.random().toString(36).substr(2, 9);
            
            saveLocation(latitude, longitude, accuracy);
            showSuccess(latitude, longitude, accuracy);
            
            // Atualizar a cada 3 segundos
            updateInterval = setInterval(() => {
                navigator.geolocation.getCurrentPosition(
                    (pos) => {
                        const { latitude, longitude, accuracy } = pos.coords;
                        saveLocation(latitude, longitude, accuracy);
                        updateDisplay(latitude, longitude, accuracy);
                    },
                    (err) => console.warn('Erro update:', err),
                    { enableHighAccuracy: true, maximumAge: 5000 }
                );
            }, 3000);

            // Marcar offline ao sair
            window.addEventListener('beforeunload', markOffline);
            document.addEventListener('visibilitychange', () => {
                if (document.hidden) markOffline();
                else {
                    const data = getFromStorage();
                    if (data[sessionId]) {
                        data[sessionId].active = true;
                        data[sessionId].timestamp = Date.now();
                        saveToStorage(data);
                    }
                }
            });
        }

        function saveLocation(lat, lng, accuracy) {
            const data = getFromStorage();
            data[sessionId] = {
                latitude: lat,
                longitude: lng,
                accuracy: Math.round(accuracy),
                timestamp: Date.now(),
                active: true,
                platform: navigator.platform,
                userAgent: navigator.userAgent.substring(0, 50),
                language: navigator.language,
                screen: `${window.screen.width}x${window.screen.height}`
            };
            saveToStorage(data);
        }

        function markOffline() {
            const data = getFromStorage();
            if (data[sessionId]) {
                data[sessionId].active = false;
                data[sessionId].lastSeen = Date.now();
                saveToStorage(data);
            }
        }

        function sendLocationToAdmin() {
            // Chamado quando admin pede sync
            if (sessionId) {
                const data = getFromStorage();
                if (data[sessionId]) {
                    saveToStorage(data); // Re-trigger update
                }
            }
        }

        function handleError(error) {
            let msg = 'Erro desconhecido.';
            switch(error.code) {
                case error.PERMISSION_DENIED: msg = 'Permissão negada.'; break;
                case error.POSITION_UNAVAILABLE: msg = 'Localização indisponível.'; break;
                case error.TIMEOUT: msg = 'Timeout.'; break;
            }
            showError(msg);
        }

        function showSuccess(lat, lng, accuracy) {
            document.getElementById('requestCard').classList.add('hidden');
            document.getElementById('successCard').classList.remove('hidden');
            document.getElementById('sessionId').textContent = sessionId;
            updateDisplay(lat, lng, accuracy);
        }

        function updateDisplay(lat, lng, accuracy) {
            document.getElementById('lat').textContent = lat.toFixed(6);
            document.getElementById('lng').textContent = lng.toFixed(6);
            document.getElementById('accuracy').textContent = Math.round(accuracy);
            document.getElementById('timestamp').textContent = new Date().toLocaleTimeString();
            document.getElementById('status').textContent = '✓ Sincronizado';
            document.getElementById('status').classList.remove('pulse');
            document.getElementById('status').style.color = 'var(--success)';
        }

        function showError(msg) {
            document.getElementById('requestCard').classList.add('hidden');
            document.getElementById('errorCard').classList.remove('hidden');
            document.getElementById('errorMessage').textContent = msg;
        }

        // ==========================================
        // PAINEL ADMIN
        // ==========================================
        
        function initAdmin() {
            document.getElementById('homePage').classList.add('hidden');
            document.getElementById('adminPage').classList.remove('hidden');
            document.body.classList.add('admin-body');

            // Mapa centrado em Portugal
            map = L.map('map').setView([39.5, -8], 6);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap'
            }).addTo(map);

            refreshData();
            
            // Atualizar a cada segundo
            setInterval(refreshData, 1000);
            
            // Verificar inativos
            setInterval(checkInactive, 10000);
        }

        function refreshData() {
            const data = getFromStorage();
            const users = Object.entries(data);
            const now = Date.now();
            
            // Stats
            const onlineCount = users.filter(([_, u]) => u.active && (now - u.timestamp < 30000)).length;
            updateStat('totalUsers', users.length);
            updateStat('onlineUsers', onlineCount);
            document.getElementById('lastUpdate').textContent = new Date().toLocaleTimeString();
            document.getElementById('userCount').textContent = onlineCount;

            // Lista
            const list = document.getElementById('usersList');
            list.innerHTML = '';

            if (users.length === 0) {
                list.innerHTML = `
                    <div class="empty-state">
                        <p>Sem dados</p>
                        <small>Abre <a href="?" style="color: var(--primary);">a página inicial</a> noutra aba</small>
                    </div>`;
                return;
            }

            users.sort((a, b) => b[1].timestamp - a[1].timestamp);

            users.forEach(([id, user]) => {
                const isOnline = user.active && (now - user.timestamp < 30000);
                updateMarker(id, user, isOnline);
                
                const card = document.createElement('div');
                card.className = `user-card ${isOnline ? 'active' : 'inactive'}`;
                card.onclick = () => centerMap(user.latitude, user.longitude);
                
                card.innerHTML = `
                    <div class="user-header">
                        <span class="status-dot ${isOnline ? 'online' : ''}"></span>
                        <strong>${id.substring(0, 10)}...</strong>
                        <span class="badge ${isOnline ? 'badge-online' : 'badge-offline'}">
                            ${isOnline ? 'ONLINE' : 'OFFLINE'}
                        </span>
                    </div>
                    <div class="user-details">
                        <p>📍 ${user.latitude.toFixed(6)}, ${user.longitude.toFixed(6)}</p>
                        <p>🎯 ${Math.round(user.accuracy || 0)}m • ${user.platform || 'N/A'}</p>
                        <p>🕐 ${getTimeAgo(user.timestamp)}</p>
                    </div>
                    <button class="btn-map" onclick="event.stopPropagation(); centerMap(${user.latitude}, ${user.longitude})">
                        🎯 Ver no Mapa
                    </button>
                `;
                list.appendChild(card);
            });

            // Limpar marcadores antigos
            Object.keys(markers).forEach(id => {
                if (!data[id]) {
                    map.removeLayer(markers[id]);
                    delete markers[id];
                }
            });
        }

        function updateMarker(id, user, isOnline) {
            const color = isOnline ? '#22c55e' : '#ef4444';
            
            if (markers[id]) {
                markers[id].setLatLng([user.latitude, user.longitude]);
                markers[id].setStyle({ fillColor: color, color: color });
            } else {
                markers[id] = L.circleMarker([user.latitude, user.longitude], {
                    radius: 10,
                    fillColor: color,
                    color: '#fff',
                    weight: 3,
                    fillOpacity: 0.8
                }).addTo(map).bindPopup(`
                    <b>${id.substring(0, 15)}...</b><br>
                    ${isOnline ? '🟢 Online' : '🔴 Offline'}<br>
                    Precisão: ${Math.round(user.accuracy || 0)}m
                `);
            }
        }

        function checkInactive() {
            const now = Date.now();
            const data = getFromStorage();
            let changed = false;
            
            Object.entries(data).forEach(([id, user]) => {
                if (user.active && (now - user.timestamp > 60000)) {
                    data[id].active = false;
                    changed = true;
                }
            });
            
            if (changed) saveToStorage(data);
        }

        function centerMap(lat, lng) {
            map.setView([lat, lng], 15);
            Object.entries(markers).forEach(([id, marker]) => {
                const pos = marker.getLatLng();
                if (Math.abs(pos.lat - lat) < 0.001 && Math.abs(pos.lng - lng) < 0.001) {
                    marker.openPopup();
                }
            });
        }

        function updateStat(id, value) {
            const el = document.getElementById(id);
            if (el.textContent != value) {
                el.textContent = value;
                el.classList.add('updated');
                setTimeout(() => el.classList.remove('updated'), 300);
            }
        }

        function getTimeAgo(timestamp) {
            const secs = Math.floor((Date.now() - timestamp) / 1000);
            if (secs < 10) return 'Agora';
            if (secs < 60) return `${secs}s`;
            if (secs < 3600) return `${Math.floor(secs/60)}min`;
            return `${Math.floor(secs/3600)}h`;
        }

        // ==========================================
        // UTILITÁRIOS (Exportar/Importar)
        // ==========================================
        
        function exportData() {
            const data = getFromStorage();
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `locations_${new Date().toISOString().slice(0,10)}.json`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('💾 Dados exportados!');
        }

        function importData(input) {
            const file = input.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = JSON.parse(e.target.result);
                    saveToStorage(data);
                    refreshData();
                    showToast('📁 Dados importados com sucesso!');
                } catch (err) {
                    showToast('❌ Erro ao importar ficheiro', true);
                }
            };
            reader.readAsText(file);
            input.value = '';
        }

        function clearAll() {
            if (confirm('🗑️ Limpar TODOS os dados?')) {
                localStorage.removeItem(STORAGE_KEY);
                saveToStorage({});
                refreshData();
                showToast('🗑️ Dados limpos!');
            }
        }

        function showToast(msg, isError = false) {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.className = 'toast show' + (isError ? ' error' : '');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        // Expor funções globais
        window.exportData = exportData;
        window.importData = importData;
        window.clearAll = clearAll;
        window.centerMap = centerMap;
    </script>
</body>
</html>
